# Dependencies
node_modules/

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo

# Environment
.env
.env.local
.env.*.local

# Archive (moved files, not needed in production)
archive/

# Claude Code memory
.claude/

# Playwright MCP debug files
.playwright-mcp/
.vercel

# Audit screenshots — large binaries, ignore everything except the JSON report
audit-output/*
!audit-output/report.json

# Local Playwright / dev screenshots — keep brand assets in inkcartridges/assets/ tracked,
# only block ad-hoc captures that land at the repo root.
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp

# One-off PDFs and ad-hoc reports dumped at the repo root
/*.pdf
/*-report.html
