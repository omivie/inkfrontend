{
  "cleanUrls": true,
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' https://cdn.jsdelivr.net https://js.stripe.com https://www.googletagmanager.com https://static.cloudflareinsights.com https://challenges.cloudflare.com https://www.paypal.com https://*.paypal.com https://*.paypalobjects.com https://apis.google.com 'sha256-0JmmTUETUXDHkK3pNmvl/MoDE5MN0DDwFCnqKmhR2Go='; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https: data:; connect-src 'self' https://ink-backend-zaeq.onrender.com https://*.supabase.co https://*.stripe.com https://*.google-analytics.com https://cdn.jsdelivr.net https://challenges.cloudflare.com https://static.cloudflareinsights.com https://*.paypal.com https://*.paypalobjects.com https://fonts.googleapis.com; frame-ancestors 'none'; frame-src https://js.stripe.com https://challenges.cloudflare.com https://*.paypal.com https://*.paypalobjects.com; upgrade-insecure-requests"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/brand/:slug", "destination": "/shop?brand=:slug", "permanent": true },
    { "source": "/brands/:slug/hub", "destination": "/shop?brand=:slug", "permanent": true },
    { "source": "/brands/:slug", "destination": "/shop?brand=:slug", "permanent": true },
    { "source": "/html/:path*", "destination": "/:path*", "permanent": true },

    { "source": "/panasonic-kxr190-191-193-194-195-196-200-210-250-300-typewriter-ribbon-lift-off-tape", "destination": "/ribbons", "permanent": true },
    { "source": "/brother-typewriter-model-listing-for-ribbons", "destination": "/ribbons", "permanent": true },
    { "source": "/typewriter-ribbons-and-cassettes", "destination": "/ribbons", "permanent": true },
    { "source": "/typewriter-ribbon-and-lift-off-tape-for-your-olivetti-lettera--series-typewriter", "destination": "/ribbons", "permanent": true },
    { "source": "/sharp-pa3000-series-correctable-typewriter-ribbon", "destination": "/ribbons", "permanent": true },
    { "source": "/group-4-olivetti-typewriter-double-spool-ribbon-black-red", "destination": "/ribbons", "permanent": true },
    { "source": "/81001.02-typewriter-ribbon-red-black-universal", "destination": "/ribbons", "permanent": true },
    { "source": "/brother-ax-typewriter-ribbons-and-lift-off-tapes", "destination": "/ribbons", "permanent": true },
    { "source": "/Panasonic-Printer-Ribbon-Compatible-for-KX-P1124-670.01", "destination": "/ribbons", "permanent": true },
    { "source": "/brother-mfc-j430w-printer", "destination": "/shop?search=Brother+MFC-J430W", "permanent": true },
    { "source": "/HL-1210W-Brother-laser-printer-uses-TN1070-Toner-cartridge-DR1070-drum", "destination": "/shop?search=Brother+HL-1210W", "permanent": true },
    { "source": "/brother-h12140-laser-printer", "destination": "/shop?search=Brother+HL-2140", "permanent": true },
    { "source": "/Brother-MFC-9340-cdw-Printer-Toner-Cartridges-TN251-TN255", "destination": "/shop?search=Brother+MFC-9340CDW", "permanent": true },
    { "source": "/hl2130-brother-laser-printer-uses-tn2030-toner-cartridge-and-dr2225-drum", "destination": "/shop?search=Brother+HL-2130", "permanent": true },
    { "source": "/hp-no.564-oem-inkjet-cartridges", "destination": "/shop?search=HP+564", "permanent": true },

    { "source": "/((?!ribbons$)[^/]*[Rr]ibbon[^/]*)", "destination": "/ribbons", "permanent": true },
    { "source": "/([^/]*[Tt]ypewriter[^/]*)", "destination": "/ribbons", "permanent": true },

    { "source": "/([^/]+)-ink-cartridges-([^/]+)", "destination": "/shop?search=$2", "permanent": true },
    { "source": "/([^/]+)-ink-cartridge-([^/]+)", "destination": "/shop?search=$2", "permanent": true },
    { "source": "/([^/]+)-inkjet-cartridges-([^/]+)", "destination": "/shop?search=$2", "permanent": true },
    { "source": "/([^/]+)-inkjet-cartridge-([^/]+)", "destination": "/shop?search=$2", "permanent": true },
    { "source": "/([^/]+)-toner-cartridges-([^/]+)", "destination": "/shop?search=$2", "permanent": true },
    { "source": "/([^/]+)-toner-cartridge-([^/]+)", "destination": "/shop?search=$2", "permanent": true },

    { "source": "/([^/]+)-laser-printer", "destination": "/shop?search=$1", "permanent": true },
    { "source": "/([^/]+)-inkjet-printer", "destination": "/shop?search=$1", "permanent": true },
    { "source": "/([^/]+)-printer", "destination": "/shop?search=$1", "permanent": true },

    { "source": "/([^/]+)-ink-cartridges", "destination": "/shop?search=$1", "permanent": true },
    { "source": "/([^/]+)-ink-cartridge", "destination": "/shop?search=$1", "permanent": true },
    { "source": "/([^/]+)-inkjet-cartridges", "destination": "/shop?search=$1", "permanent": true },
    { "source": "/([^/]+)-inkjet-cartridge", "destination": "/shop?search=$1", "permanent": true },
    { "source": "/([^/]+)-toner-cartridges", "destination": "/shop?search=$1", "permanent": true },
    { "source": "/([^/]+)-toner-cartridge", "destination": "/shop?search=$1", "permanent": true },

    { "source": "/ink-cartridges", "destination": "/shop?category=ink", "permanent": true },
    { "source": "/toner-cartridges", "destination": "/shop?category=toner", "permanent": true },
    { "source": "/printers/:slug", "destination": "/shop?printer=:slug", "permanent": true },
    { "source": "/genuine-vs-compatible", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://ink-backend-zaeq.onrender.com/api/:path*" },

    {
      "source": "/html/shop",
      "has": [{ "type": "query", "key": "printer" }],
      "destination": "https://ink-backend-zaeq.onrender.com/html/shop"
    },
    {
      "source": "/shop",
      "has": [{ "type": "query", "key": "printer" }],
      "missing": [
        { "type": "query", "key": "brand" },
        { "type": "query", "key": "printer_slug" }
      ],
      "destination": "https://ink-backend-zaeq.onrender.com/shop"
    },

    { "source": "/shop", "destination": "/html/shop" },
    { "source": "/search", "destination": "/html/shop" },
    { "source": "/cart", "destination": "/html/cart" },
    { "source": "/checkout", "destination": "/html/checkout" },
    { "source": "/payment", "destination": "/html/payment" },
    { "source": "/order-confirmation", "destination": "/html/order-confirmation" },
    { "source": "/ribbons", "destination": "/html/ribbons" },
    { "source": "/account", "destination": "/html/account" },
    { "source": "/account/:path*", "destination": "/html/account/:path*" },
    { "source": "/admin", "destination": "/html/admin" },
    { "source": "/admin/:path*", "destination": "/html/admin/:path*" },
    { "source": "/auth/reset-password", "destination": "/html/account/reset-password" },
    { "source": "/business/apply", "destination": "/html/business/apply" },
    { "source": "/ribbon/:sku", "destination": "/html/product" },
    { "source": "/product-by-name", "destination": "https://ink-backend-zaeq.onrender.com/html/product-by-name" },
    { "source": "/products/:slug/:sku", "destination": "/html/product?sku=:sku" },
    { "source": "/product/:slug", "destination": "/html/product?slug=:slug" },
    { "source": "/p/:sku", "destination": "/html/product?sku=:sku" },
    { "source": "/sitemap.xml", "destination": "https://ink-backend-zaeq.onrender.com/sitemap.xml" },
    { "source": "/sitemap-:path.xml", "destination": "https://ink-backend-zaeq.onrender.com/sitemap-:path.xml" },
    { "source": "/feeds/google-shopping.xml", "destination": "https://ink-backend-zaeq.onrender.com/feeds/google-shopping.xml" },
    { "source": "/feeds/facebook-catalog.tsv", "destination": "https://ink-backend-zaeq.onrender.com/feeds/facebook-catalog.tsv" },
    { "source": "/feeds/google-promotions.xml", "destination": "https://ink-backend-zaeq.onrender.com/feeds/google-promotions.xml" },
    { "source": "/robots.txt", "destination": "https://ink-backend-zaeq.onrender.com/robots.txt" }
  ]
}
